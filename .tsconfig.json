{
    "compilerOptions": {
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "types": [
            "vite/client",
            "node"
        ],
        "typeRoots": [
            "./node_modules/@types",
            "./src/types"
        ],
        "allowImportingTsExtensions": true,
        "jsx": "preserve",
        "jsxImportSource": "vue"
    },
    "include": [
        "plugins/**/*.ts",
        "plugins/**/*.d.ts",
        "**/*.d.ts"
    ]
}