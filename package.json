{
  "name": "slidev-theme-whu-landing",
  "version": "0.0.2",
  "type": "module",
  "keywords": [
    "slidev-theme",
    "slidev"
  ],
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "build": "slidev build slides/main.md",
    "dev": "slidev slides/main.md --open",
    "export": "slidev export slides/main.md",
    "screenshot": "slidev export slides/main.md --format png",
    "release": "changeset publish"
  },
  "pnpm": {
    "overrides": {
      "debug": "^4.3.4"
    }
  },
  "dependencies": {
    "@citation-js/core": "^0.7.21",
    "@citation-js/plugin-bibtex": "^0.7.21",
    "@citation-js/plugin-csl": "^0.7.22",
    "@citation-js/plugin-doi": "^0.7.21",
    "@slidev/theme-default": "^0.25.0",
    "@slidev/types": "^52.14.2",
    "@viarotel-org/unocss-preset-shades": "^0.8.2",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "slidev-addon-naive": "^0.9.0",
    "slidev-addon-stem": "^0.1.3",
    "slidev-addon-typst": "^1.0.2",
    "slidev-component-progress": "^1.1.0",
    "slidev-component-scroll": "^1.1.0",
    "unocss-preset-palette": "^0.4.0",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@iconify-json/material-symbols": "^1.2.69",
    "@iconify/vue": "^5.0.0",
    "@slidev/cli": "latest",
    "prettier": "^3.8.3",
    "prettier-plugin-slidev": "^1.0.5",
    "unplugin-vue-components": "^32.0.0"
  },
  "//": "Learn more: https://sli.dev/guide/write-theme.html",
  "slidev": {
    "colorSchema": "both",
    "defaults": {
      "fonts": {
        "sans": "Source Han Sans",
        "mono": "JetBrains Mono"
      }
    },
    "addons": [
      "naive"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}